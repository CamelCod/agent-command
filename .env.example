# .env.example — copy to .env and fill in your values

# ─── Moonshot API (used by the /v1/chat/completions proxy) ───
# Server-side only — NEVER expose this to the browser.
MOONSHOT_API_KEY=k1-...

# ─── GitHub OAuth (for Export to GitHub feature) ───
# Register an OAuth App at: https://github.com/settings/applications/new
# Set the callback URL to: https://your-domain.com/v1/auth/github/callback
GITHUB_CLIENT_ID=Ov23c...
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_CALLBACK_URL=https://your-domain.com/v1/auth/github/callback

# ─── Session ────────────────────────────────────────────────────
# Random secret for signing session cookies (min 32 chars).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace-with-a-long-random-secret

# ─── Feature Flags ────────────────────────────────────────────
# URL checked by /v1/user/subscription to verify premium status.
# Before Stripe/LemonSqueezy integration: set to any URL that returns {"premium": false}
# After integration: point to your billing webhook handler.
PREMIUM_CHECK_URL=https://your-domain.com/api/v1/user/subscription

# ─── Database / Paths ─────────────────────────────────────────
MEMORIA_DB_PATH=./memoria.db
GENOME_PATH=./genomes/
